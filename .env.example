# .env.example
# Environment Variables for CDSS Healthcare

# ============================================================================
# 🚀 Application
# ============================================================================
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
VERSION=3.0.0

# ============================================================================
# 🌐 API
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=True

# ============================================================================
# 🔐 Security
# ============================================================================
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=your-encryption-key-change-in-production

# ============================================================================
# 🗄️ Database
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cdss
DB_USER=cdss
DB_PASSWORD=cdss_password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================================================
# 📊 Redis
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_TTL=3600
REDIS_MAX_CONNECTIONS=20

# ============================================================================
# 📊 MLflow
# ============================================================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=cdss_healthcare

# ============================================================================
# 🔄 Celery
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500

# ============================================================================
# 📊 Monitoring
# ============================================================================
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=True
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ============================================================================
# ☁️ Cloud (AWS)
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_DATA=cdss-data
S3_BUCKET_MODELS=cdss-models

# ============================================================================
# 🔔 Alerts
# ============================================================================
SLACK_WEBHOOK_URL=
PAGERDUTY_SERVICE_KEY=
PAGERDUTY_ROUTING_KEY=

# ============================================================================
# 📧 Email
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=alerts@cdss-healthcare.com
SMTP_TO=admin@cdss-healthcare.com

# ============================================================================
# 🧪 Testing
# ============================================================================
TESTING=True
TEST_DB_NAME=cdss_test
TEST_REDIS_DB=1
TESTING_RATE_LIMIT=1000