# .env
# Environment Variables

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=True

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cdss
DB_USER=cdss
DB_PASSWORD=cdss_password

# MLflow
MLFLOW_TRACKING_URI=file:./experiments/mlflow

# Security
JWT_SECRET_KEY=your-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100

# AWS (if using)
AWS_REGION=us-east-1
S3_BUCKET_DATA=cdss-data
S3_BUCKET_MODELS=cdss-models